# Copy to .env and adjust. All optional; defaults shown.

# Docker daemon socket (mounted from the host).
DOCKER_SOCKET=/var/run/docker.sock

# Image used for spawned DF instances. Match what you built/deployed.
DF_IMAGE=remote-df:df-53_14

# Where instance data lives. DATA_ROOT is the path INSIDE this panel container;
# HOST_DATA_ROOT is the SAME directory's path on the HOST (Docker interprets
# bind-mount sources on the host, not inside this container). They are usually
# different — see control-panel/README.md.
DATA_ROOT=/data
HOST_DATA_ROOT=/home/ubuntu/remote-df/control-panel/data

# First loopback port handed to a spawned instance; subsequent ones increment.
BASE_PORT=6090

# Default resource limits applied to spawned instances.
DF_CPUS=2.0
DF_MEMORY=3g
