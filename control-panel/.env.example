# Copy to .env and adjust. All optional; defaults shown.

# --- Docker connection -------------------------------------------------------
# Leave DOCKER_HOST unset to use the local socket (mount it in compose).
# To deploy to a REMOTE daemon, set one of:
#   DOCKER_HOST=tcp://HOST:2376      # with TLS (recommended) — see below
#   DOCKER_HOST=ssh://user@HOST      # over SSH (set DOCKER_SSH_KEY or use an agent)
DOCKER_HOST=
DOCKER_SOCKET=/var/run/docker.sock

# For tcp:// with TLS: point at a dir containing ca.pem, cert.pem, key.pem.
DOCKER_TLS_VERIFY=
DOCKER_CERT_PATH=

# For ssh://: path to a private key the panel can read (mount it in).
DOCKER_SSH_KEY=

# --- Instances ---------------------------------------------------------------
# Image used for spawned DF instances. Must exist on the TARGET daemon's host.
DF_IMAGE=remote-df:df-53_14

# Where the panel stores uploaded mods/tilesets (inside this container).
DATA_ROOT=/data

# First loopback port handed to a spawned instance; subsequent ones increment.
# These ports are on the TARGET daemon's host.
BASE_PORT=6090

# Default resource limits applied to spawned instances.
DF_CPUS=2.0
DF_MEMORY=3g
